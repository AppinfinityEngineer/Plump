{
  "cli": {
    "version": ">= 18.12.3",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "autoIncrement": false,
      "env": {
        "EXPO_PUBLIC_PAYWALL_MODE": "dev"
      }
    },
    "preview": {
      "distribution": "internal",
      "autoIncrement": false,
      "env": {
        "EXPO_PUBLIC_PAYWALL_MODE": "review"
      }
    },
    "production": {
      "autoIncrement": false,
      "env": {
        "EXPO_PUBLIC_PAYWALL_MODE": "production"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
