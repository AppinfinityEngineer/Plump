{
  "expo": {
    "name": "Plump",
    "slug": "plump",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "plump",
    "owner": "thoughtsnap-labs-ltd",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.thoughtsnaplabs.plump",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "buildNumber": "4"
    },
    "android": {
      "package": "com.thoughtsnaplabs.plump",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FBF4E9"
      },
      "edgeToEdgeEnabled": true,
      "versionCode": 4
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-image.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#FBF4E9"
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Fredoka-Regular.ttf",
            "./assets/fonts/Fredoka-SemiBold.ttf",
            "./assets/fonts/Fredoka-Bold.ttf",
            "./assets/fonts/Nunito-Regular.ttf",
            "./assets/fonts/Nunito-SemiBold.ttf",
            "./assets/fonts/Nunito-Bold.ttf",
            "./assets/fonts/Nunito-ExtraBold.ttf"
          ]
        }
      ],
      "react-native-iap",
      "./plugins/with-privacy-manifest"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "appStoreSku": "PLUMP-IOS-001",
      "launchVersion": "1.0.0",
      "launchBuildNumber": "4",
      "router": {},
      "eas": {
        "projectId": "56959484-8acd-4a80-bde3-a0dd0be71e92"
      }
    }
  }
}
