# Plump backend environment

# MongoDB Atlas connection string.
# Render should use the staging/prod Atlas URI directly in the dashboard env vars.
MONGO_URL=mongodb+srv://<user>:<password>@<cluster-host>/?retryWrites=true&w=majority

# Database name. Use plump_staging for Render staging and plump_prod for production.
DB_NAME=plump_staging

# Environment name for logs/proofs.
ENVIRONMENT=staging

# Required for protected write endpoints:
# POST /api/v1/events
# POST /api/v1/sync
#
# Generate with PowerShell:
# [Convert]::ToBase64String((1..48 | ForEach-Object { Get-Random -Maximum 256 }))
PLUMP_DEVICE_AUTH_SECRET=<long-random-secret>
